{
  "name": "delphinet6",
  "private": true,
  "version": "0.0.1",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace @delphinet/api",
    "dev:web": "npm run dev --workspace @delphinet/web",
    "build:api": "npm run build --workspace @delphinet/api",
    "build:web": "npm run build --workspace @delphinet/web",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "db:generate": "npx prisma generate --schema prisma/schema.prisma",
    "db:migrate": "npx prisma migrate dev --schema prisma/schema.prisma",
    "db:push": "npx prisma db push --schema prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "npx prisma studio --schema prisma/schema.prisma"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "prettier": "^3.3.3",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  }
}
