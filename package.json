{
  "name": "delphinet6",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev:api": "pnpm --filter @delphinet/api dev",
    "dev:web": "pnpm --filter @delphinet/web dev",
    "build:api": "pnpm --filter @delphinet/api build",
    "build:web": "pnpm --filter @delphinet/web build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:push": "prisma db push --schema prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio --schema prisma/schema.prisma"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "prisma": "^5.19.1",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "argon2",
      "esbuild",
      "prisma"
    ]
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  }
}
