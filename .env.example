# Database
DATABASE_URL=postgresql://delphinet:delphinet@db:5432/delphinet

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://cache:6379

# App
PORT=3000
NODE_ENV=development
SCHOOL_TIMEZONE=America/Los_Angeles

# Super-admin bootstrap password.
#  - If unset, the seed creates the default super-admin
#    (ari@aricummings.com) with the well-known password 'adminpassword'.
#    Existing super-admin's password is left untouched.
#  - If set, the seed creates *or rotates* the super-admin password to
#    this value on every run. Use this to recover a lost password by
#    setting it here, running `docker compose up -d --build`, then
#    unsetting it again.
# SUPER_ADMIN_PASSWORD=change-me
